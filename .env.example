TZ=Europe/Madrid
CUADERNOPRO_PORT=8503
# 127.0.0.1: recomendado para uso local/proxy, no expone Streamlit directamente en la red.
# 0.0.0.0: permite acceso desde la red local; usar solo si se entiende el riesgo.
CUADERNOPRO_BIND_ADDRESS=127.0.0.1
COMPOSE_PROJECT_NAME=cuadernopro

# Para una segunda instalacion en el mismo servidor, usar otro nombre de
# proyecto y otro puerto, por ejemplo:
# COMPOSE_PROJECT_NAME=cuadernopro_demo
# CUADERNOPRO_PORT=8504

CUADERNOPRO_DB_PATH=/app/runtime/cuadernopro.db
CUADERNOPRO_BACKUPS_DIR=/app/runtime/backups
CUADERNOPRO_EXPORTS_DIR=/app/runtime/exports
CUADERNOPRO_DOCUMENTOS_DIR=/app/runtime/documentos

# Acceso exterior opcional con Caddy
# Para uso local normal no hace falta activar esto.
# Para activar:
# docker compose --profile proxy up -d
#
# En acceso exterior, publica solo el proxy y no abras el puerto de Streamlit
# CUADERNOPRO_PORT a Internet.
# start_proxy.sh exige CUADERNOPRO_BIND_ADDRESS=127.0.0.1 para limitar el
# puerto local de Streamlit al propio servidor.
CUADERNOPRO_DOMAIN=cuadernopro.ejemplo.es
CUADERNOPRO_PROXY_HTTP_PORT=80
CUADERNOPRO_PROXY_HTTPS_PORT=443
CUADERNOPRO_PROXY_USER=admin
CUADERNOPRO_PROXY_PASSWORD_HASH=

# Generar hash:
# ./proxy_hash_password.sh
